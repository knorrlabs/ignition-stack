GATEWAY_NAME=module-install-poc
GATEWAY_HTTP_PORT=9088
ADMIN_PASSWORD=password
TZ=America/Los_Angeles
MODL_PATH=/Users/eknorr/IA/code/projects/ignition-stack/scripts/seeding-poc/.modl-cache/MQTT-Engine-signed-5.0.2.modl

# Three env vars cooperate for a clean third-party module install in 8.3:
# GATEWAY_MODULES_ENABLED whitelists module identifiers (restricts uninstall),
# ACCEPT_MODULE_LICENSES auto-accepts each listed module's third-party license,
# ACCEPT_MODULE_CERTS auto-trusts each listed module's signing certificate.
# All three take comma-delimited fully-qualified identifiers (NOT paths).
GATEWAY_MODULES_ENABLED=com.cirruslink.mqtt.engine.gateway
ACCEPT_MODULE_LICENSES=com.cirruslink.mqtt.engine.gateway
ACCEPT_MODULE_CERTS=com.cirruslink.mqtt.engine.gateway
