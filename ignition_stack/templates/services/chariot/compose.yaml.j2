{{ name }}:
  image: {{ image_ref }}
  hostname: {{ name }}
  container_name: {{ container_name_ref }}
  environment:
    TZ: ${TZ}
    ACCEPT_EULA: "true"
    ADMIN_PASSWORD: ${CHARIOT_ADMIN_PASSWORD}
  ports:
    - "${CHARIOT_HTTP_PORT}:8080"
    - "${CHARIOT_MQTT_PORT}:1883"
{%- if networks %}
  networks:
{%- for net in networks %}
    - {{ net }}
{%- endfor %}
{%- endif %}

{{ name }}-trial:
  image: {{ image_ref }}
  container_name: {{ container_name_ref }}-trial
  restart: "no"
  depends_on:
    - {{ name }}
  entrypoint: ["/bin/sh", "/chariot-trial.sh"]
  environment:
    # Chariot's web admin is the fixed image user `admin`; ADMIN_PASSWORD on the
    # broker service sets its password. The script defaults the user to `admin`.
    CHARIOT_HOST: {{ name }}
    CHARIOT_ADMIN_USER: admin
    CHARIOT_ADMIN_PASSWORD: ${CHARIOT_ADMIN_PASSWORD}
  volumes:
    - ./services/{{ name }}/chariot-trial.sh:/chariot-trial.sh:ro
{%- if networks %}
  networks:
{%- for net in networks %}
    - {{ net }}
{%- endfor %}
{%- endif %}
